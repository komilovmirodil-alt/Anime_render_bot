# Telegram bot token from BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Optional: your Telegram numeric user ID
ADMIN_ID=123456789

# Optional: channel link shown to non-admin users on /start
CHANNEL_URL=https://t.me/your_channel

# Optional: channel numeric ID for membership check (required for subscription feature)
CHANNEL_ID=-1001234567890
